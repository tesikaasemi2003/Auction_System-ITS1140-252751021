<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="450.0" prefWidth="620.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.time_auction_system_its1140.ClientController">
    <children>
        <Label layoutX="210.0" layoutY="14.0" prefHeight="30.0" prefWidth="171.0" text="          Client">
            <font><Font size="24.0" /></font>
        </Label>

        <!-- Username row -->
        <Label layoutX="20.0" layoutY="52.0" text="Username:" />
        <TextField fx:id="txtUsername" layoutX="90.0" layoutY="48.0" prefHeight="28.0" prefWidth="380.0" promptText="Enter your username..." />
        <Button layoutX="480.0" layoutY="48.0" onAction="#setUsernameAction" prefHeight="28.0" prefWidth="110.0" text="Set Name" />

        <!-- Status label -->
        <Label fx:id="lblStatus" layoutX="14.0" layoutY="169.0" style="-fx-text-fill: gray;" text="Connecting..." />

        <!-- Message row -->
        <TextField fx:id="txtMessage" layoutX="20.0" layoutY="400.0" prefHeight="30.0" prefWidth="460.0" promptText="Bid Amount: " />
        <Button layoutX="490.0" layoutY="400.0" onAction="#sendOnAction" prefHeight="30.0" prefWidth="110.0" text="Place Bid" />
      <Button fx:id="btnDisconnect" layoutX="480.0" layoutY="92.0" mnemonicParsing="false" onAction="#sendOnDisconnect" prefHeight="26.0" prefWidth="110.0" style="-fx-background-color: red;" text="Disconnect" textFill="#faf9f9" />
      <TextField layoutX="14.0" layoutY="92.0" onAction="#setItem" prefHeight="26.0" prefWidth="449.0" promptText="item:" />
      <TextField layoutX="14.0" layoutY="135.0" onAction="#currentHighestBid" prefHeight="26.0" prefWidth="449.0" promptText="Current Highest Bid" />
      <ScrollPane layoutX="14.0" layoutY="194.0" prefHeight="191.0" prefWidth="590.0">
        <content>
          <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="200.0" prefWidth="200.0">
               <children>
                  <TextArea fx:id="txtArea" prefHeight="191.0" prefWidth="575.0" />
               </children>
            </AnchorPane>
        </content>
      </ScrollPane>
    </children>
</AnchorPane>
